Output docs/images/04-which-key.gif
Set Shell "bash"
Set FontSize 14
Set Width 1200
Set Height 700
Set Theme "Catppuccin Mocha"
Set Framerate 24
Set PlaybackSpeed 1
Set TypingSpeed 50ms
Set Padding 20

Hide
Type "cd /tmp/neovibe-demo"
Enter
Sleep 500ms
Show

Type "NVIM_APPNAME=neovibe nvim"
Enter
Sleep 3s

Type "f"
Sleep 1s

Type "index"
Sleep 500ms
Enter
Sleep 1.5s

Type " "
Sleep 2s

Type "f"
Sleep 2s

Escape
Sleep 1s

Type " "
Sleep 1.5s

Type "g"
Sleep 2s

Type ":qa!"
Enter
Sleep 500ms
