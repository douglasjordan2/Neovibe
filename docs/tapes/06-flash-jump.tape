Output docs/images/06-flash-jump.gif
Set Shell "bash"
Set FontSize 14
Set Width 1200
Set Height 700
Set Theme "Catppuccin Mocha"
Set Framerate 24
Set PlaybackSpeed 1
Set TypingSpeed 50ms
Set Padding 20

Hide
Type "cd /tmp/neovibe-demo"
Enter
Sleep 500ms
Show

Type "NVIM_APPNAME=neovibe nvim"
Enter
Sleep 3s

Type "f"
Sleep 1s

Type "task.ts"
Sleep 500ms
Enter
Sleep 2s

Type "ss"
Sleep 500ms

Type "va"
Sleep 1.5s

Escape
Sleep 1s

Type ":qa!"
Enter
Sleep 500ms
